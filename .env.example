HOST=127.0.0.1       # 监听地址，仅本机访问用 127.0.0.1
PORT=8080            # 监听端口（与 OneBot V11 客户端配置一致）
SUPERUSERS=[]        # 管理员 QQ 号，如 ["123456789"]
NICKNAME=["bot"]     # 机器人昵称

# === SillyTavern Bridge 配置 ===
ST_BASE_URL=http://127.0.0.1:8000  # SillyTavern 地址
ST_CHAT_SOURCE=deepseek             # AI 后端名称（对应 ST 连接配置）
ST_MODEL=                           # 已废弃 — 留空，模型由 ST 预设指定
ST_TIMEOUT=120                      # 请求超时（秒）
ST_MAX_RESPONSE_LENGTH=800          # 最大回复长度
ST_DEFAULT_CHARACTER=               # 默认角色 avatar_url（留空则首次使用时选择）
ST_DEFAULT_PRESET=                  # 默认预设名称（留空则使用 ST 默认预设）

# === 自动群聊参与（默认值，各群可通过 /auto 命令覆盖） ===
ST_AUTO_ENABLED=false               # 默认关闭，需 /auto on 手动开启
ST_AUTO_MSG_THRESHOLD=3             # 触发所需不同用户数
ST_AUTO_MSG_WINDOW=30               # 时间窗口（秒）
ST_AUTO_COOLDOWN=120                # 冷却时间（秒）
ST_AUTO_PROBABILITY=30              # 触发概率（百分比，0-100）
